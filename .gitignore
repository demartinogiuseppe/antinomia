# Build output
node_modules/
main.js
main.js.map

# Vitest coverage output
coverage/

# Backup automatico di main.ts (gestito da esbuild.config.mjs)
backups/

# Test vault di sviluppo (intero, NON pubblico).
# Il plugin viene buildato qui per testarlo durante lo sviluppo, ma le note
# personali del vault non devono finire pubbliche.
TestVault/

# Test vault disordinato (vecchio benchmark italiano, ora obsoleto in v1.2 full English).
# Il vault esempio English e' generato dal plugin via Settings -> Onboarding -> Create examples.
TestVaultDisordinato/

# Note timestamp generate runtime durante test (T-YYYYMMDD-..., S-YYYYMMDD-...)
# Lasciano stato del repo pulito senza note ephemeral. Le note ESEMPIO-* del vault
# di esempio NON sono toccate da questi pattern.
TestVaultDisordinato/notes/T-2*.md
TestVaultDisordinato/notes/S-2*.md
TestVault/notes/T-2*.md
TestVault/notes/S-2*.md

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Test / scratch files from initial setup
check_env.bat
check_env.ps1
check_output.txt
ps_log.txt

# Archivi compressi (manuali di backup, non versionati)
*.rar
*.zip
*.7z

# Script one-shot di migrazione tra fasi (transienti di questa sessione)
# package-release.ps1 NON e' coperto da questi pattern (e' uno strumento stabile, tracked).
fase*-*.ps1
audit-*.ps1
cleanup-*.ps1
onboarding-*.ps1
release-v*.ps1
reorganize-*.ps1

# Artefatti di release (vanno solo su GitHub Release, non nel repo)
releases/
release-temp/
