# Build output
plugin/node_modules/
plugin/main.js.map

# Backup automatico di main.ts (gestito da esbuild.config.mjs)
plugin/backups/

# Test vault (contains user data + plugin build copy)
TestVault/.obsidian/plugins/antinomia/main.js
TestVault/.obsidian/plugins/antinomia/data.json
TestVault/.obsidian/workspace*
TestVault/.obsidian/cache

# Test vault disordinato (vault separato per misurazione Hunter)
TestVaultDisordinato/.obsidian/plugins/antinomia/main.js
TestVaultDisordinato/.obsidian/plugins/antinomia/data.json
TestVaultDisordinato/.obsidian/workspace*
TestVaultDisordinato/.obsidian/cache

# Note timestamp generate runtime durante test (T-YYYYMMDD-..., S-YYYYMMDD-...)
# Lasciano stato del repo pulito senza note ephemeral. Le note ESEMPIO-* del vault
# di esempio NON sono toccate da questi pattern.
TestVaultDisordinato/notes/T-2*.md
TestVaultDisordinato/notes/S-2*.md
TestVault/notes/T-2*.md
TestVault/notes/S-2*.md

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Test / scratch files from initial setup
check_env.bat
check_env.ps1
check_output.txt
ps_log.txt

# Archivi compressi (manuali di backup, non versionati)
*.rar
*.zip
*.7z

# Script one-shot di migrazione tra fasi (transienti di questa sessione)
# package-release.ps1 NON e' coperto da questo pattern (e' uno strumento stabile, tracked).
fase*-*.ps1

# Artefatti di release (vanno solo su GitHub Release, non nel repo)
releases/
release-temp/
